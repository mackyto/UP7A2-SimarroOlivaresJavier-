<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <!-- El nombre de la unidad de persistencia lo usas en el Persistence.createEntityManagerFactory("MiUnidadMySQL") -->
    <persistence-unit name="gamversLibros" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Aquí debes listar tus clases @Entity (Hibernate suele auto-detectarlas, pero es buena práctica listarlas) -->
        <!-- <class>com.tu.paquete.TuClase</class> -->

        <properties>
            <!-- 1. Configuración de la conexión a MySQL -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://gamvers.xyz:3306/Libros?serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user" value="javier"/>
            <property name="jakarta.persistence.jdbc.password" value="hqxjt8"/>

            <!-- 2. Dialecto de Hibernate para MySQL 8+ -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>

            <!-- 3. Magia: Hibernate crea las tablas por ti si no existen -->
            <!-- Valores: update (crea/actualiza), create (borra y crea siempre), none -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- 4. Mostrar el SQL por consola (muy útil para debugear) -->
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
            <property name="hibernate.use_sql_comments" value="false"/>
        </properties>
    </persistence-unit>
</persistence>

